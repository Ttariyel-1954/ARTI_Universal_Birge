# ═══════════════════════════════════════════════════════════════
# CLAUDE_MODEL_TƏMIR_TIKINTI — MÜHIT DƏYIŞƏNLƏRI ŞABLONU
# Bu faylı kopyalayıb .env adı ilə saxlayın və doldurun
# ═══════════════════════════════════════════════════════════════

# ═══ APPLICATION ═══
NODE_ENV=development
APP_NAME="TTİS Universal Agent"
APP_VERSION=0.1.0

# ═══ SERVER ═══
PORT=3001
HOST=localhost
API_PREFIX=/api/v1

# ═══ DOMAIN — AKTIV BIZNES SAHƏSI ═══
# Mümkün variantlar: construction, pharmacy, logistics, education
DOMAIN=construction

# ═══ DATABASE (PostgreSQL) ═══
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ttis_db
DB_USER=royatalibova
DB_PASSWORD=
DB_SCHEMA=public
DB_POOL_MIN=2
DB_POOL_MAX=10

# ═══ AUTHENTICATION ═══
JWT_SECRET=change_this_to_random_long_string_in_production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ═══ CLAUDE AI (Anthropic) ═══
# https://console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_MAX_TOKENS=4096

# ═══ FRONTEND ═══
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:3838

# ═══ SHINY DASHBOARD ═══
SHINY_PORT=3838
SHINY_HOST=localhost

# ═══ FILE UPLOAD ═══
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25
ALLOWED_FILE_TYPES=pdf,jpg,png,docx,xlsx

# ═══ LOGGING ═══
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ═══ TAILSCALE (uzaq deploy) ═══
TAILSCALE_IP=100.116.171.28
REMOTE_USER=tariyel
REMOTE_PORT=3001
